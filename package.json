{
  "name": "ecommerce-eurostar",
  "version": "1.0.0",
  "description": "In-memory e-commerce REST API with JWT authentication and checkout",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "mocha test/**/*.js --reporter mochawesome --reporter-options reportDir=mochawesome-report,reportFilename=test-report"
  },
  "keywords": ["ecommerce", "express", "rest-api"],
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "express": "^4.21.2",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "mocha": "^10.2.0",
    "chai": "^4.3.10",
    "supertest": "^6.3.3",
    "mochawesome": "^7.1.3"
  }
}
